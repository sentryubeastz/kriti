{
  "manifest_version": 3,
  "name": "Kriti",
  "version": "1.0.0",
  "description": "Get word meanings and translations from selected text on any webpage, with local note storage",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  }
}
